// Prisma schema for HotelShift Pro

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // will hash in production
  firstName String
  lastName  String
  role      UserRole @default(EMPLOYEE)
  status    UserStatus @default(ACTIVE)
  
  // Relations
  employee  Employee?
  admin     Admin?
  sessions  Session[]
  timeLogs  TimeLog[]
  vouchers  Voucher[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum UserRole {
  EMPLOYEE
  ADMIN
  MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// EMPLOYEE & ADMIN
// ============================================

model Employee {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  employeeId   String   @unique // HR ID
  phone        String?
  department   String?
  
  // Pay info
  hourlyRate   Float
  bankAccount  String?
  taxId        String?
  
  // Preferences
  roles        String[] // ["FRONT_DESK", "SHUTTLE"]
  shiftPrefs   String[] // ["MORNING", "EVENING", "NIGHT"]
  
  // Relations
  timeLogs     TimeLog[]
  voucherLogs  VoucherLog[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
  @@index([userId])
}

model Admin {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  permissions String[] // ["VIEW_ALL", "EDIT_TIME", "OVERRIDE_VOUCHER", etc.]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ============================================
// TIME TRACKING
// ============================================

model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role        ShiftRole // FRONT_DESK or SHUTTLE
  shiftType   ShiftType // MORNING, EVENING, NIGHT, SHUTTLE
  
  clockInTime   DateTime
  clockOutTime  DateTime?
  
  status      SessionStatus @default(OPEN)
  
  // Earnings
  basePayAmount Float?
  tipsAmount    Float?
  bonusAmount   Float?
  
  // Multi-session shuttle tracking
  dailyTotal    Float? // For shuttle multi-session summary
  
  // Admin override/edit tracking
  editedBy      String?
  editedAt      DateTime?
  editReason    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  timeLogs      TimeLog[]

  @@index([userId])
  @@index([clockInTime])
  @@index([status])
}

enum ShiftRole {
  FRONT_DESK
  SHUTTLE
}

enum ShiftType {
  MORNING
  EVENING
  NIGHT
  SHUTTLE
}

enum SessionStatus {
  OPEN      // Currently clocked in
  COMPLETED // Clocked out, finalized
  PENDING_REVIEW // Awaiting admin review
  EDITED    // Modified by admin
  CONFLICTED // Overlapping sessions
}

model TimeLog {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  sessionId   String
  session     Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Raw time entry
  startTime   DateTime
  endTime     DateTime?
  duration    Int? // minutes
  
  // Modifiers
  roomBonus   Int? // count of rooms/passengers
  roomValue   Float?
  
  status      TimeLogStatus @default(PENDING)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([employeeId])
  @@index([sessionId])
}

enum TimeLogStatus {
  PENDING
  APPROVED
  DECLINED
  ADJUSTED
}

// ============================================
// VOUCHERS & SCANNING
// ============================================

model Voucher {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Scanned data
  cardNumber String // masked: ****1234
  room      String   @db.VarChar(10)
  passengerCount Int
  
  // Bonus tracking
  bonusAmount Float
  status      VoucherStatus @default(ACCEPTED)
  
  // Decline reason if applicable
  declineReason String?
  declinedAt    DateTime?
  
  scannedAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([scannedAt])
  @@index([status])
}

enum VoucherStatus {
  ACCEPTED
  DECLINED
  PENDING_REVIEW
}

model VoucherLog {
  id          String  @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  voucherId   String
  action      String // "SCAN", "DECLINE", "ADJUST"
  details     Json   // flexible field for meta
  
  createdAt   DateTime @default(now())

  @@index([employeeId])
}

// ============================================
// PAYROLL & ESTIMATION
// ============================================

model PayPeriod {
  id          String   @id @default(cuid())
  
  startDate   DateTime
  endDate     DateTime
  
  status      PayPeriodStatus @default(OPEN)
  finalized   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startDate])
  @@index([status])
}

enum PayPeriodStatus {
  OPEN      // Still collecting hours/vouchers
  LOCKED    // No more edits allowed
  FINALIZED // Payroll generated
}

model PayEstimate {
  id          String   @id @default(cuid())
  
  employeeId  String
  payPeriodId String
  
  // Breakdown
  basePay     Float // hours * rate
  tips        Float
  roomBonus   Float
  voucherBonus Float
  soldOutBonus Float
  
  totalEstimated Float
  
  // Status
  isFinalized Boolean @default(false)
  finalizedAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, payPeriodId])
  @@index([employeeId])
  @@index([payPeriodId])
}

// ============================================
// AUDIT & COMPLIANCE
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  
  action    String   // "CLOCK_IN", "CLOCK_OUT", "EDIT_TIME", "DECLINE_VOUCHER", etc.
  userId    String
  adminId   String?  // if action taken by admin
  
  entityType String  // "SESSION", "VOUCHER", "PAYSTUB"
  entityId  String
  
  changes   Json     // { field: { before, after } }
  reason    String?  // Why the change was made
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

// ============================================
// APP CONFIG & SETTINGS
// ============================================

model AppConfig {
  id            String @id @default(cuid())
  
  // Feature flags
  enableVoucherScanning Boolean @default(true)
  enableOfflineMode     Boolean @default(true)
  enableMultiSession    Boolean @default(true)
  
  // Pay rules
  baseSoldOutBonus      Float @default(5.0)
  roomUpsellRate        Float @default(1.5)
  voucherBonusRate      Float @default(0.25)
  
  // Config
  updatedAt             DateTime @updatedAt
}
