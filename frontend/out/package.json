{
  "name": "hotelshift-pro",
  "version": "1.0.0",
  "description": "Premium employee management & time tracking PWA for hospitality",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "npm run dev:stop && concurrently -k -n APP,RT -c cyan,magenta \"npm:dev\" \"npm:realtime\"",
    "dev:status": "lsof -nP -iTCP:3000 -sTCP:LISTEN || true; lsof -nP -iTCP:3001 -sTCP:LISTEN || true; lsof -nP -iTCP:4001 -sTCP:LISTEN || true",
    "dev:stop": "lsof -ti:3000,3001,4001 | xargs kill -15 2>/dev/null || true",
    "realtime": "node scripts/realtime-server.js",
    "realtime:status": "lsof -nP -iTCP:4001 -sTCP:LISTEN || true",
    "realtime:stop": "lsof -ti:4001 | xargs kill -15 2>/dev/null || true",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@tanstack/react-query": "^5.28.0",
    "@tanstack/react-query-devtools": "^5.28.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.0",
    "date-fns": "^2.30.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.294.0",
    "next": "14.2.35",
    "postcss": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.0",
    "recharts": "^2.10.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.7.0",
    "tailwindcss": "^3.4.0",
    "tesseract.js": "^7.0.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "concurrently": "^9.0.1",
    "eslint": "^8.54.0",
    "eslint-config-next": "14.2.35",
    "prettier": "^3.1.0",
    "prisma": "^5.7.0"
  }
}
