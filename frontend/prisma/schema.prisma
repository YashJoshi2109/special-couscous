generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  email     String     @unique
  password  String
  firstName String
  lastName  String
  role      UserRole   @default(EMPLOYEE)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  admin     Admin?
  employee  Employee?
  sessions  Session[]
  timeLogs  TimeLog[]
  vouchers  Voucher[]

  @@index([email])
  @@index([username])
}

model Employee {
  id          String       @id @default(cuid())
  userId      String       @unique
  employeeId  String       @unique
  phone       String?
  department  String?
  hourlyRate  Float
  bankAccount String?
  taxId       String?
  roles       String[]
  shiftPrefs  String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeLogs    TimeLog[]
  voucherLogs VoucherLog[]

  @@index([employeeId])
  @@index([userId])
}

model Admin {
  id          String   @id @default(cuid())
  userId      String   @unique
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id            String        @id @default(cuid())
  userId        String
  role          ShiftRole
  shiftType     ShiftType
  clockInTime   DateTime
  clockOutTime  DateTime?
  status        SessionStatus @default(OPEN)
  basePayAmount Float?
  tipsAmount    Float?
  bonusAmount   Float?
  dailyTotal    Float?
  editedBy      String?
  editedAt      DateTime?
  editReason    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeLogs      TimeLog[]

  @@index([userId])
  @@index([clockInTime])
  @@index([status])
}

model TimeLog {
  id         String        @id @default(cuid())
  userId     String
  employeeId String
  sessionId  String
  startTime  DateTime
  endTime    DateTime?
  duration   Int?
  roomBonus  Int?
  roomValue  Float?
  status     TimeLogStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  session    Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([employeeId])
  @@index([sessionId])
}

model Voucher {
  id             String        @id @default(cuid())
  userId         String
  cardNumber     String
  room           String        @db.VarChar(10)
  passengerCount Int
  expiryDate     String?
  bonusAmount    Float
  status         VoucherStatus @default(ACCEPTED)
  declineReason  String?
  declinedAt     DateTime?
  scannedAt      DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scannedAt])
  @@index([status])
}

model VoucherLog {
  id         String   @id @default(cuid())
  employeeId String
  voucherId  String
  action     String
  details    Json
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model PayPeriod {
  id        String          @id @default(cuid())
  startDate DateTime
  endDate   DateTime
  status    PayPeriodStatus @default(OPEN)
  finalized DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([startDate])
  @@index([status])
}

model PayEstimate {
  id             String    @id @default(cuid())
  employeeId     String
  payPeriodId    String
  basePay        Float
  tips           Float
  roomBonus      Float
  voucherBonus   Float
  soldOutBonus   Float
  totalEstimated Float
  isFinalized    Boolean   @default(false)
  finalizedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([employeeId, payPeriodId])
  @@index([employeeId])
  @@index([payPeriodId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  userId     String
  adminId    String?
  entityType String
  entityId   String
  changes    Json
  reason     String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model AppConfig {
  id                    String   @id @default(cuid())
  enableVoucherScanning Boolean  @default(true)
  enableOfflineMode     Boolean  @default(true)
  enableMultiSession    Boolean  @default(true)
  baseSoldOutBonus      Float    @default(5.0)
  roomUpsellRate        Float    @default(1.5)
  voucherBonusRate      Float    @default(0.25)
  updatedAt             DateTime @updatedAt
}

enum UserRole {
  EMPLOYEE
  ADMIN
  MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ShiftRole {
  FRONT_DESK
  SHUTTLE
}

enum ShiftType {
  MORNING
  EVENING
  NIGHT
  SHUTTLE
}

enum SessionStatus {
  OPEN
  COMPLETED
  PENDING_REVIEW
  EDITED
  CONFLICTED
}

enum TimeLogStatus {
  PENDING
  APPROVED
  DECLINED
  ADJUSTED
}

enum VoucherStatus {
  ACCEPTED
  DECLINED
  PENDING_REVIEW
}

enum PayPeriodStatus {
  OPEN
  LOCKED
  FINALIZED
}
